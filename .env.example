# Example environment variables for local development
# Copy this file to .env and replace placeholders with real values.

# Private server-side API key (keep secret, do NOT commit real key)
VAPI_PRIVATE_KEY=your-private-vapi-key-here

# Public key used by client-side Vapi Web SDK (safe to expose)
VAPI_PUBLIC_KEY=your-public-vapi-key-here

# Assistant ID (from Vapi dashboard)
VAPI_ASSISTANT_ID=your-assistant-id-here

# Backend server URL (adjust if your backend runs on a different port or host)
BACKEND_URL=http://localhost:8000
